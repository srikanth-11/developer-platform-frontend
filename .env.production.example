# Production build config. In Vercel, set this as a Project Environment Variable
# (Production) instead of committing a real .env.production.
#
# Vite bakes VITE_* vars into the bundle AT BUILD TIME, so this must point at the
# deployed backend on Render. Get the URL from the Render dashboard, e.g.
# https://developer-platform-backend.onrender.com  -> append /api
VITE_API_BASE_URL=https://developer-platform-backend.onrender.com/api
